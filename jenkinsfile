pipeline {
    agent any

    environment {
        IMAGE_NAME = "vaibhav6060/academy"
        IMAGE_TAG  = "${BUILD_NUMBER}"
    }

    stages {
        stage('Clone') {
            steps {
                git branch: 'main',
                url: 'https://github.com/Vaibhav6060/academy-project.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                docker build -t $IMAGE_NAME:$IMAGE_TAG .
                docker tag $IMAGE_NAME:$IMAGE_TAG $IMAGE_NAME:latest
                '''
            }
        }

        stage('Push Image') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {
                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                    docker push $IMAGE_NAME:$IMAGE_TAG
                    docker push $IMAGE_NAME:latest
                    '''
                }
            }
        }

        stage('Deploy To EKS') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'aws-creds',
                        usernameVariable: 'AWS_ACCESS_KEY_ID',
                        passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                    )
                ]) {
                    sh """
                    export AWS_DEFAULT_REGION=eu-north-1
                    
                    # 1. Apply the new mixed deployment layout and Nginx web routing service
                    kubectl apply -f academy-deployment.yaml -n academy
                    kubectl apply -f nginx-service.yaml -n academy
                    
                    # 2. Upgrade the container images across the deployment stack simultaneously
                    # This triggers both the initContainer and the app container to update
                    kubectl set image deployment/academy-stack \\
                    laravel=${IMAGE_NAME}:${IMAGE_TAG} \\
                    code-provider=${IMAGE_NAME}:${IMAGE_TAG} \\
                    -n academy

                    # 3. Track rollout until completely healthy and running
                    kubectl rollout status deployment/academy-stack -n academy
                    """
                }
            }
        }
    }

    post {
        success {
            withCredentials([
                usernamePassword(
                    credentialsId: 'aws-creds', 
                    usernameVariable: 'AWS_ACCESS_KEY_ID', 
                    passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                )
            ]) {
                sh """
                export AWS_DEFAULT_REGION=eu-north-1
                echo '========================================================================'
                echo '🚀 DEPLOYMENT SUCCESSFUL!'
                echo '🎯 Access your Laravel application in the browser using this URL:'
                echo ''
                
                # Dynamic fetch of the live AWS Load Balancer DNS target
                kubectl get svc nginx-service -n academy -o jsonpath='{.status.loadBalancer.ingress[0].hostname}'
                
                echo '\n========================================================================'
                """
            }
        }
        failure {
            echo '❌ Deployment Failed'
        }
    }
}
